# Django
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# Database
POSTGRES_DB=sms_db
POSTGRES_USER=sms_user
POSTGRES_PASSWORD=sms_password
POSTGRES_HOST=db
